# Cerberus Beacon — 환경 변수 예시
# cp .env.sample .env 후 필요한 항목만 주석 해제하세요.
# 우선순위: CLI 인자 > OS 환경변수 > 이 파일 > 기본값

# ── 메타 ──────────────────────────────────────────────────────────────────────
# CB_ENV_FILE=.env           # .env 파일 경로 (OS 환경변수로만 지정, 이 파일에 쓰면 무의미)

# ── 서버 ──────────────────────────────────────────────────────────────────────
#CB_PORT=8765                # 웹 서버 포트
#CB_IDLE_TIMEOUT=5           # 터널 유휴 자동 종료 (분, 0=비활성)
#CB_SERVER_IDLE_MINUTES=5    # 서버 자체 유휴 자동 종료 (분, 0=비활성)

# ── 인증 ──────────────────────────────────────────────────────────────────────
#CB_SESSION_HOURS=1          # 브라우저 세션 유지 시간 (시)
#CB_MAX_ATTEMPTS=5           # 로그인 최대 실패 횟수
#CB_WINDOW_MINUTES=5         # 실패 횟수 집계 윈도우 (분)
#CB_LOCKOUT_MINUTES=15       # 잠금 지속 시간 (분)

# ── 터널 ──────────────────────────────────────────────────────────────────────
#CB_TUNNEL_MODE=quick        # quick | named
#CB_TUNNEL_NAME=             # Named Tunnel 이름 (CB_TUNNEL_MODE=named 시)
#CB_TUNNEL_DOMAIN=           # Named Tunnel 도메인

# ── 파일 브라우저 ─────────────────────────────────────────────────────────────
#CB_FILES_ROOT=~             # 파일 브라우저 루트 경로
#CB_FILES_HIDDEN=0           # 숨김 파일 표시 (1=표시)
#CB_FILES_EXCLUDE=~/.cerberus,~/.ssh  # 제외 경로 (쉼표 구분). ~/.cerberus는 항상 차단
#CB_MAX_UPLOAD_BYTES=104857600  # 업로드 최대 크기 (기본 100MB)

# ── 에이전트 API ──────────────────────────────────────────────────────────────
#CB_AGENT=1                  # 에이전트 API 활성 (0=비활성, /api/agent/* 차단)

# ── 터미널 ────────────────────────────────────────────────────────────────────
#CB_TERMINAL=0               # 웹 터미널 활성 (1=활성, --terminal 플래그와 동일)
#CB_TERMINAL_SHELL=/bin/bash # 터미널 기본 쉘
#CB_MAX_SESSIONS=50          # 최대 동시 터미널 세션 수

# ── 세션 로그 ─────────────────────────────────────────────────────────────────
#CB_SESSION_LOG=1            # 터미널 세션 로그 기록 (0=비활성)
#CB_SESSION_LOG_DIR=~/.cerberus/sessions  # 로그 저장 디렉터리
#CB_SESSION_LOG_MAX_MB=50    # 로그 파일 최대 크기 (MB, 초과 시 rotate)
#CB_SESSION_LOG_MAX_DAYS=7   # 로그 보관 기간 (일, 초과 시 자동 삭제)

# ── Telegram 봇 ───────────────────────────────────────────────────────────────
#CB_TG_TOKEN=                # Telegram 봇 토큰 (1234567890:AAHxxx...)
#CB_TG_CHAT_ID=0             # Telegram Chat ID

# ── Slack 봇 ──────────────────────────────────────────────────────────────────
#CB_SLACK_BOT=               # Slack xoxb- 토큰
#CB_SLACK_APP=               # Slack xapp- 토큰
#CB_SLACK_CHANNEL=#general   # Slack 채널

# ── UI ────────────────────────────────────────────────────────────────────────
#CB_LANG=                    # UI 언어 (ko | en | 빈값=OS 자동 감지)

# ── 메트릭 ────────────────────────────────────────────────────────────────────
#CB_METRICS_DISK_PATH=       # 디스크 사용량 측정 경로 (기본: CB_FILES_ROOT)
